# Cloudflare Pages / Netlify headers.
# Apple's universal-links CDN requires the AASA file to be served as JSON.
# GitHub Pages serves extensionless files as application/octet-stream and
# can't override this — which is why the deeplink needs a header-capable host.
/.well-known/apple-app-site-association
  Content-Type: application/json
  Cache-Control: public, max-age=3600

# Cache static assets for a week (filenames are stable; bump on real changes).
/assets/*
  Cache-Control: public, max-age=604800

# Security headers on every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
